---
import { execSync } from 'node:child_process';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import VisitedMap from '../components/VisitedMap.astro';
import { Image } from 'astro:assets';
import cafeImage from '../assets/cafe.png';
import location from '../data/location.json';

let locationUpdatedAt: string | null = null;
try {
  const isoDate = execSync('git log -1 --format=%cI -- src/data/location.json', {
    cwd: process.cwd(),
  })
    .toString()
    .trim();
  if (isoDate) {
    locationUpdatedAt = new Date(isoDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }
} catch {
  locationUpdatedAt = null;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Kristin Ng" description="Curious. Relentless. Lifelong learner." />
  </head>
  <body>
    <div class="viewport-hero">
      <Header />
      <div class="hero-image">
        <Image
          src={cafeImage}
          alt="Cozy cafe workspace with books, bicycle, and coffee"
          width={1400}
        />
        <div class="matcha-hover-zone" tabindex="0" aria-label="Matcha recipe">
          <div class="matcha-tooltip">
            <strong>Simple Matcha Recipe</strong>
            <ul>
              <li>Sift 3g matcha powder</li>
              <li>Add 30g of 80&deg;C water</li>
              <li>Swirl the bowl and cover the matcha with water</li>
              <li>Whisk in an M shape motion until foam appears</li>
              <li>[optional] add sweetener and whisk</li>
              <li>Add to milk</li>
              <li>Enjoy!</li>
            </ul>
          </div>
        </div>
      </div>

      <main>
        <h1>Kristin Ng</h1>
        <p class="tagline">Curious. Relentless. Lifelong learner.</p>
        <p class="description">
          My goal is to be comfortable in discomfort. That's where most growth happens.
        </p>

        <div class="location">
          <h3>Where is Kristin?</h3>
          <a href={`https://www.google.com/maps/place/${location.mapQuery}`} target="_blank" rel="noopener noreferrer">📍{location.city}</a>
          {locationUpdatedAt && <span class="location-updated">Last updated {locationUpdatedAt}</span>}
        </div>
      </main>
    </div>

    <section class="map-section">
      <VisitedMap />
    </section>

    <section class="social-section">
      <SocialLinks />
    </section>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
  }

  body {
    background: #faf9f7;
  }

  .viewport-hero {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .map-section {
    background: #faf9f7;
  }

  .social-section {
    background: #faf9f7;
    display: flex;
    justify-content: center;
    padding: 0 2rem 3rem;
  }

  .hero-image {
    flex: 1;
    min-height: 0;
    line-height: 0;
    position: relative;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .matcha-hover-zone {
    position: absolute;
    left: 50%;
    top: 35%;
    width: 25%;
    height: 26%;
    cursor: help;
    outline: none;
  }

  .matcha-tooltip {
    position: absolute;
    right: calc(100% + 0.6rem);
    top: 50%;
    transform: translateY(-50%) translateX(6px);
    width: max-content;
    max-width: 240px;
    background: rgba(250, 249, 247, 0.97);
    color: rgb(15, 18, 25);
    border: 1px solid rgba(96, 115, 159, 0.25);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    box-shadow: 0 8px 24px rgba(15, 18, 25, 0.18);
    text-align: left;
    font-size: 0.85rem;
    line-height: 1.45;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 10;
  }

  .matcha-tooltip strong {
    display: block;
    margin-bottom: 0.4rem;
    color: rgb(96, 115, 159);
    font-size: 0.9rem;
  }

  .matcha-tooltip ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .matcha-tooltip li {
    margin-bottom: 0.25rem;
  }

  .matcha-tooltip li:last-child {
    margin-bottom: 0;
  }

  .matcha-hover-zone:hover .matcha-tooltip,
  .matcha-hover-zone:focus-visible .matcha-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }

  main {
    flex-shrink: 0;
    text-align: center;
    padding: 2rem 2rem 2.2rem;
    width: 100%;
    box-sizing: border-box;
  }

  h1 {
    font-size: 3.2rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
    color: rgb(15, 18, 25);
  }

  .tagline {
    font-size: 1.15rem;
    font-style: italic;
    color: rgb(96, 115, 159);
    margin: 0 0 0.9rem;
    letter-spacing: 0.01em;
  }

  .description {
    font-size: 1rem;
    color: rgb(96, 115, 159);
    max-width: 40rem;
    margin: 0 auto 1.8rem;
    line-height: 1.5;
  }

  .location {
    margin: 0 0 1.2rem;
  }

  .location h3 {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(15, 18, 25);
    margin: 0 0 0.3rem;
  }

  .location a {
    font-size: 0.95rem;
    color: rgb(96, 115, 159);
    text-decoration: none;
  }

  .location a:hover {
    text-decoration: underline;
  }

  .location-updated {
    display: block;
    font-size: 0.75rem;
    color: rgb(140, 148, 163);
    margin-top: 0.2rem;
  }

  @media (max-width: 640px) {
    .matcha-tooltip {
      position: fixed;
      left: 50%;
      right: auto;
      top: auto;
      bottom: 1.25rem;
      width: calc(100vw - 2.5rem);
      max-width: 320px;
      transform: translateX(-50%) translateY(8px);
    }

    .matcha-hover-zone:hover .matcha-tooltip,
    .matcha-hover-zone:focus-visible .matcha-tooltip {
      transform: translateX(-50%) translateY(0);
    }
  }

  @media (max-width: 380px) {
    main {
      padding: 1.5rem 1rem 1.8rem;
    }

    h1 {
      font-size: 2.5rem;
    }
  }
</style>
