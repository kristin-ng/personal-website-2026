---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import cafeImage from '../assets/cafe.png';
import socialLinks from '../data/social-links.json';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Kristin Ng" description="Curious. Relentless. Lifelong learner." />
  </head>
  <body>
    <Header />
    <div class="hero-image">
      <Image
        src={cafeImage}
        alt="Cozy cafe workspace with books, bicycle, and coffee"
        width={1400}
      />
      <div class="matcha-hover-zone" tabindex="0" aria-label="Matcha recipe">
        <div class="matcha-tooltip">
          <strong>Simple Matcha Recipe</strong>
          <ul>
            <li>Sift 3g matcha powder</li>
            <li>Add 30g of 80&deg;C water</li>
            <li>Swirl the bowl and cover the matcha with water</li>
            <li>Whisk in an M shape motion until foam appears</li>
            <li>[optional] add sweetener and whisk</li>
            <li>Add to milk</li>
            <li>Enjoy!</li>
          </ul>
        </div>
      </div>
    </div>

    <main>
      <h1>Kristin Ng</h1>
      <p class="tagline">Curious. Relentless. Lifelong learner.</p>
      <p class="description">
        My goal is to be comfortable in discomfort. That's where most growth happens.
      </p>

      <div class="social-links">
        <a
          href={socialLinks.linkedin || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <a
          href={socialLinks.twitter || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter / X"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>

        <a
          href={socialLinks.strava || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Strava"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169z"/>
          </svg>
        </a>

        <a
          href={socialLinks.beli || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Beli"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/>
          </svg>
        </a>

        <a
          href={socialLinks.substack || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Substack"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
          </svg>
        </a>

        <a
          href={socialLinks.github || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>

        <a
          href={socialLinks.goodreads || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Goodreads"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.346.026c.422-.083.859.037 1.179.325.346.284.55.705.557 1.153-.023.457-.247.88-.612 1.156l-2.182 1.748a.601.601 0 0 0-.255.43.52.52 0 0 0 .11.424 5.886 5.886 0 0 1 .832 6.58c-1.394 2.79-4.503 3.99-7.501 2.927a.792.792 0 0 0-.499-.01c-.224.07-.303.18-.453.383l-.014.02-.941 1.254s-.792.985.457.935c3.027-.119 3.817-.119 5.439-.01 2.641.18 3.806 1.903 3.806 3.275 0 1.623-1.036 3.383-3.809 3.383a117.46 117.46 0 0 0-5.517-.03c-.31.005-.597.013-.835.02-.228.006-.41.011-.52.011-.712 0-1.648-.186-1.66-1.068-.008-.729.624-1.12 1.11-1.172.43-.045.815.007 1.24.064.252.034.518.07.815.088.185.011.366.025.552.038.53.038 1.102.08 1.926.087.427.005.759.01 1.025.015.695.012.941.016 1.28-.015 1.248-.112 1.832-.61 1.832-1.376 0-.805-.584-1.264-1.698-1.414-1.564-.213-2.33-.163-3.72-.074a87.66 87.66 0 0 1-1.669.095c-.608.029-2.449.026-2.682-1.492-.053-.416-.073-1.116.807-2.325l.75-1.003c.36-.49.582-.898.053-1.559 0 0-.39-.468-.52-.638-1.215-1.587-1.512-4.08-.448-6.114 1.577-3.011 5.4-4.26 8.37-2.581.253.143.438.203.655.163.201-.032.27-.167.363-.344.02-.04.042-.082.067-.126.004-.01.241-.465.535-1.028l.734-1.41a1.493 1.493 0 0 1 1.041-.785ZM9.193 13.243c1.854.903 3.912.208 5.254-2.47 1.352-2.699.827-5.11-1.041-6.023C10.918 3.537 8.81 5.831 8.017 7.41c-1.355 2.698-.717 4.886 1.147 5.818Z"/>
          </svg>
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  html, body {
    height: 100dvh;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  body {
    background: #faf9f7;
    display: flex;
    flex-direction: column;
  }

  .hero-image {
    flex: 1;
    min-height: 0;
    line-height: 0;
    position: relative;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .matcha-hover-zone {
    position: absolute;
    left: 50%;
    top: 35%;
    width: 25%;
    height: 26%;
    cursor: help;
    outline: none;
  }

  .matcha-tooltip {
    position: absolute;
    right: calc(100% + 0.6rem);
    top: 50%;
    transform: translateY(-50%) translateX(6px);
    width: max-content;
    max-width: 240px;
    background: rgba(250, 249, 247, 0.97);
    color: rgb(15, 18, 25);
    border: 1px solid rgba(96, 115, 159, 0.25);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    box-shadow: 0 8px 24px rgba(15, 18, 25, 0.18);
    text-align: left;
    font-size: 0.85rem;
    line-height: 1.45;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 10;
  }

  .matcha-tooltip strong {
    display: block;
    margin-bottom: 0.4rem;
    color: rgb(96, 115, 159);
    font-size: 0.9rem;
  }

  .matcha-tooltip ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .matcha-tooltip li {
    margin-bottom: 0.25rem;
  }

  .matcha-tooltip li:last-child {
    margin-bottom: 0;
  }

  .matcha-hover-zone:hover .matcha-tooltip,
  .matcha-hover-zone:focus-visible .matcha-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }

  main {
    flex-shrink: 0;
    text-align: center;
    padding: 2rem 2rem 2.2rem;
    width: 100%;
    box-sizing: border-box;
  }

  h1 {
    font-size: 3.2rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
    color: rgb(15, 18, 25);
  }

  .tagline {
    font-size: 1.15rem;
    font-style: italic;
    color: rgb(96, 115, 159);
    margin: 0 0 0.9rem;
    letter-spacing: 0.01em;
  }

  .description {
    font-size: 1rem;
    color: rgb(96, 115, 159);
    max-width: 40rem;
    margin: 0 auto 1.8rem;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 1.6rem;
    justify-content: center;
    align-items: center;
  }

  .social-links a {
    color: rgb(96, 115, 159);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .social-links a:hover {
    color: rgb(15, 18, 25);
  }

  .social-links svg {
    width: 26px;
    height: 26px;
    fill: currentColor;
  }

  @media (max-width: 380px) {
    main {
      padding: 1.5rem 1rem 1.8rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .social-links {
      gap: 1rem;
    }

    .social-links svg {
      width: 22px;
      height: 22px;
    }
  }
</style>
