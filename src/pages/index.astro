---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import cafeImage from '../assets/cafe.png';
import socialLinks from '../data/social-links.json';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Kristin Ng" description="Curious. Relentless. Lifelong learner." />
  </head>
  <body>
    <Header />
    <div class="hero-image">
      <Image
        src={cafeImage}
        alt="Cozy cafe workspace with books, bicycle, and coffee"
        width={1400}
      />
    </div>

    <main>
      <h1>Kristin Ng</h1>
      <p class="tagline">Curious. Relentless. Lifelong learner.</p>
      <p class="description">
        My goal is to be comfortable in discomfort. That's where most growth happens.
      </p>

      <div class="social-links">
        <a
          href={socialLinks.linkedin || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <a
          href={socialLinks.twitter || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter / X"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>

        <a
          href={socialLinks.strava || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Strava"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169z"/>
          </svg>
        </a>

        <a
          href={socialLinks.beli || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Beli"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/>
          </svg>
        </a>

        <a
          href={socialLinks.substack || '#'}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Substack"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
          </svg>
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  html, body {
    height: 100dvh;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  body {
    background: #faf9f7;
    display: flex;
    flex-direction: column;
  }

  .hero-image {
    flex: 1;
    min-height: 0;
    line-height: 0;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  main {
    flex-shrink: 0;
    text-align: center;
    padding: 2rem 2rem 2.2rem;
    width: 100%;
    box-sizing: border-box;
  }

  h1 {
    font-size: 3.2rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
    color: rgb(15, 18, 25);
  }

  .tagline {
    font-size: 1.15rem;
    font-style: italic;
    color: rgb(96, 115, 159);
    margin: 0 0 0.9rem;
    letter-spacing: 0.01em;
  }

  .description {
    font-size: 1rem;
    color: rgb(96, 115, 159);
    white-space: nowrap;
    margin: 0 auto 1.8rem;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 1.6rem;
    justify-content: center;
    align-items: center;
  }

  .social-links a {
    color: rgb(96, 115, 159);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .social-links a:hover {
    color: rgb(15, 18, 25);
  }

  .social-links svg {
    width: 26px;
    height: 26px;
    fill: currentColor;
  }
</style>
