---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import StatusDot from '../../components/StatusDot.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				background: #faf9f7;
			}
			main {
				width: 720px;
			}
			ul {
				display: flex;
				flex-direction: column;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 1rem;
				width: 100%;
				padding: 1.25rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li:last-child {
				border-bottom: none;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.project-link {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}
			ul li img {
				width: 120px;
				height: 90px;
				object-fit: cover;
				border-radius: 8px;
				flex-shrink: 0;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.project-link:hover .title,
			.project-link:hover .date {
				color: rgb(var(--accent));
			}
			.meta {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.4rem;
				margin-left: auto;
				flex-shrink: 0;
			}
			.see-updates {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.see-updates:hover {
				color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				ul li {
					gap: 0.75rem;
					padding: 1rem 0;
				}
				.project-link {
					gap: 1rem;
				}
				ul li img {
					width: 80px;
					height: 60px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						projects.map((project) => (
							<li>
								<a
									class="project-link"
									href={project.data.url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{project.data.heroImage && (
										<Image width={240} height={180} src={project.data.heroImage} alt="" />
									)}
									<div>
										<h4 class="title">{project.data.title}</h4>
										<p class="date">
											<FormattedDate date={project.data.pubDate} />
										</p>
									</div>
								</a>
								<div class="meta">
									<StatusDot status={project.data.status} />
									{project.data.updates && project.data.updates.length > 0 && (
										<a class="see-updates" href={`${import.meta.env.BASE_URL}projects/${project.id}/`}>
											See updates →
										</a>
									)}
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
