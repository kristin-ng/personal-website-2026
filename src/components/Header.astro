---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<HeaderLink href={import.meta.env.BASE_URL}>Home</HeaderLink>
		<HeaderLink href={`${import.meta.env.BASE_URL}blog`}>Blog</HeaderLink>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5rem;
		background: #faf9f7;
		flex-shrink: 0;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1.8rem;
		height: 52px;
	}
	nav :global(a) {
		font-size: 0.95rem;
		text-decoration: none;
		color: rgb(96, 115, 159);
		letter-spacing: 0.03em;
		transition: color 0.2s ease;
	}
	nav :global(a:hover),
	nav :global(a.active) {
		color: rgb(15, 18, 25);
	}
	nav :global(a.active) {
		font-weight: 600;
	}
</style>
